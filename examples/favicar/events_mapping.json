{
  "source": "service_visits",
  "entities": [
    {
      "type": "Client",
      "source_path": "$[*]",
      "primary_key": "$[*].clientId",
      "description": "Service Center Customer."
    },
    {
      "type": "Car",
      "source_path": "$[*]",
      "primary_key": "$[*].vehicleId",
      "description": "The customer's car is serviced at this service station."
    },
    {
      "type": "ServiceVisit",
      "source_path": "$[*]",
      "primary_key": "$[*].id",
      "description": "A central service-event entity representing a customer's vehicle visit to an automotive workshop.",
      "properties": [
        {
          "name": "id",
          "type": "Keyword",
          "source_path": "$[*].id"
        },
        {
          "name": "work_start",
          "type": "DateTime",
          "source_path": "$[*].startUtc",
          "description": "Start time."
        },
        {
          "name": "work_end",
          "type": "DateTime",
          "source_path": "$[*].endUtc",
          "description": "End time."
        },
        {
          "name": "work_start",
          "type": "DateTime",
          "source_path": "$[*].startUtc",
          "description": "Start time."
        },
        {
          "name": "client_concerns",
          "type": "Text",
          "source_path": "$[*].customerWork",
          "description": "Description of the customer's request."
        }
      ]
    },
    {
      "type": "WorkItem",
      "source_path": "$[*].stationWorks[*]",
      "primary_key": "{$[*].id}-{$[*].stationWorks[*].id}",
      "description": "Work performed during the service visit.",
      "properties": [
        {
          "name": "Name",
          "type": "Text",
          "source_path": "$[*].stationWorks[*].displayName",
          "description": "Work name."
        },
        {
          "name": "cost",
          "type": "Number",
          "source_path": "$[*].stationWorks[*].costTotal",
          "description": "Cost of the work."
        }
      ]
    }
  ],
  "relationships": [
    {
      "type": "VISITED",
      "from": "Client",
      "to": "ServiceVisit"
    },
    {
      "type": "FOR_CAR",
      "from": "ServiceVisit",
      "to": "Car"
    },
    {
      "type": "INCLUDES_WORK",
      "from": "ServiceVisit",
      "to": "WorkItem"
    }
  ]
}
