{
  "action": "find",
  "start": { "label": "Camera", "alias": "c" },
  "traversals": [
    {
      "edge": { "label": "LOCATED_IN", "alias": "loc", "direction": "out" },
      "target": { "label": "Place", "alias": "p" }
    },
    {
      "edge": { "label": "LOCATED_IN", "alias": "loc2", "direction": "out" },
      "target": { "label": "Location", "alias": "l" }
    }
  ],
  "filters": [
    { "field": "l.name", "op": "eq", "value": "Алмата" }
  ],
  "return": [
    { "field": "c.id", "alias": "camera_id" },
    { "field": "c.name", "alias": "camera_name" }
  ]
}