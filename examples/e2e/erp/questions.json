{
  "questions": [
    {
      "id": "customer_by_description",
      "question": "Найди клиента по описанию про складскую инфраструктуру.",
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "Customer",
          "required_filter_fields": ["description"],
          "required_filter_ops": ["contains"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "Нортвинд Казахстан" }
        ]
      }
    },
    {
      "id": "customer_manager",
      "question": "Кто является менеджером клиента Глобекс Ритейл Казахстан?",
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "Customer",
          "required_traversal_labels": ["CUSTOMER_MANAGER"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "Павел Ким" }
        ]
      }
    },
    {
      "id": "order_product",
      "question": "Какой продукт связан с заказом Обновление оборудования Нортвинд?",
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "SalesOrder",
          "required_filter_fields": ["name"],
          "required_traversal_labels": ["ORDER_LINE", "LINE_PRODUCT"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "Комплект управления запасами" }
        ]
      }
    },
    {
      "id": "invoice_status",
      "question": "Какой статус у инвойса INV-1001?",
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "Invoice",
          "required_filter_fields": ["invoice_number"],
          "required_filter_ops": ["eq"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "просрочен" }
        ]
      }
    },
    {
      "id": "open_pending_orders",
      "question": "Какие заказы находятся в активной обработке или ожидают следующего действия?",
      "validation": {
        "row_count": { "exact": 3 },
        "dsl_expect": {
          "start_label": "SalesOrder",
          "required_filter_fields": ["status"],
          "required_filter_ops": ["in"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "Обновление оборудования Нортвинд" },
          { "column": "*", "mode": "contains", "value": "Годовой договор поставок Глобекс" },
          { "column": "*", "mode": "contains", "value": "Срочный заказ запасных частей Сигма" }
        ]
      }
    },
    {
      "id": "purchase_supplier",
      "question": "К какому поставщику относится закупка PO-7781?",
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "PurchaseOrder",
          "required_filter_fields": ["number"],
          "required_filter_ops": ["eq"],
          "required_traversal_labels": ["PURCHASE_ORDER_SUPPLIER"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "Ару Логистикс" }
        ]
      }
    },
    {
      "id": "shipment_warehouse",
      "question": "К какому складу относится отгрузка SHP-9002?",
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "Shipment",
          "required_filter_ops": ["eq"],
          "required_traversal_labels": ["SHIPMENT_WAREHOUSE"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "Шымкентский склад запасных частей" }
        ]
      }
    },
    {
      "id": "invoice_payment",
      "question": "Какой платеж связан с инвойсом INV-1002?",
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "Invoice",
          "required_filter_fields": ["invoice_number"],
          "required_filter_ops": ["eq"],
          "required_traversal_labels": ["INVOICE_PAYMENT"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "PAY-9001" }
        ]
      }
    },
    {
      "id": "warehouse_by_description",
      "question": "Найди склад по описанию про холодовую цепочку и розничные отгрузки.",
      "validation": {
        "row_count": { "exact": 1 },
        "contains": [
          { "column": "*", "mode": "contains", "value": "Алматинский распределительный центр" }
        ]
      }
    },
    {
      "id": "invoice_by_date",
      "question": "Какой инвойс выставлен на 2026-07-02?",
      "dsl": {
        "action": "find",
        "start": { "label": "Invoice", "alias": "i" },
        "filters": [
          {
            "field": "i.invoice_date",
            "op": "eq",
            "value": "2026-07-02"
          }
        ],
        "return": [
          { "field": "i.invoice_number", "alias": "invoice_number" },
          { "field": "i.subject", "alias": "subject" },
          { "field": "i.invoice_date", "alias": "invoice_date" }
        ],
        "limit": 1
      },
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "Invoice",
          "required_filter_fields": ["invoice_date"],
          "required_filter_ops": ["eq"]
        },
        "contains": [
          { "column": "*", "mode": "contains", "value": "INV-1002" }
        ]
      }
    },
    {
      "id": "open_sales_order_count",
      "question": "Сколько заказов находятся в статусе открыт?",
      "dsl": {
        "action": "aggregate",
        "start": { "label": "SalesOrder", "alias": "so" },
        "filters": [
          {
            "field": "so.status",
            "op": "eq",
            "value": "открыт"
          }
        ],
        "return": [
          { "aggregate": "count", "field": "so.id", "alias": "open_order_count" }
        ],
        "group_by": []
      },
      "validation": {
        "row_count": { "exact": 1 },
        "dsl_expect": {
          "start_label": "SalesOrder",
          "required_filter_fields": ["status"],
          "required_filter_ops": ["eq"],
          "required_return_fields": ["open_order_count"]
        },
        "numbers": [
          { "column": "open_order_count", "op": "gt", "value": 0 }
        ]
      }
    }
  ]
}
