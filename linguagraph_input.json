{
  "action": "aggregate",
  "start": {
    "label": "WorkItem",
    "alias": "w"
  },
  "traversals": [
    {
      "from": "w",
      "edge": {
        "label": "INCLUDES_WORK",
        "alias": "iw",
        "direction": "in"
      },
      "target": {
        "label": "ServiceVisit",
        "alias": "sv"
      }
    },
    {
      "from": "sv",
      "edge": {
        "label": "FOR_CAR",
        "alias": "fc",
        "direction": "in"
      },
      "target": {
        "label": "Car",
        "alias": "c"
      }
    }
  ],
  "filters": [
    {
      "field": "c.name",
      "op": "contains",
      "value": "BMW 3"
    },
    {
      "field": "w.Name",
      "op": "contains",
      "value": "замена масла"
    }
  ],
  "return": [
    {
      "aggregate": "avg",
      "field": "w.cost",
      "alias": "avg_cost"
    }
  ],
  "limit": 1
}