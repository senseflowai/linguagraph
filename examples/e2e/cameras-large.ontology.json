          { "name": "name", "property_type": "keyword", "required": true },
          { "name": "state", "property_type": "keyword", "required": false },
          { "name": "state_reason", "property_type": "keyword", "required": false },
          { "name": "is_dvr", "property_type": "bool", "required": false },
          { "name": "edge", "property_type": "bool", "required": false },
          { "name": "place_id", "property_type": "keyword", "required": false },
          { "name": "created_at", "property_type": "keyword", "required": false },
          { "name": "updated_at", "property_type": "keyword", "required": false },
          { "name": "scheduler_group", "property_type": "keyword", "required": false },
          { "name": "capacitygroup_token", "property_type": "keyword", "required": false },
          { "name": "storage_depth", "property_type": "int", "required": false },
          { "name": "source_host", "property_type": "keyword", "required": false }
        ]
      },
      {
