{
  "action": "aggregate",
  "start": {
    "label": "Camera",
    "alias": "c"
  },
  "traversals": [],
  "filters": [
    {
      "field": "c.created_at",
      "op": "gte",
      "value": "2023-01-01T00:00:00Z"
    },
    {
      "field": "c.created_at",
      "op": "lte",
      "value": "2026-12-31T23:59:59Z"
    }
  ],
  "return": [
    {
      "aggregate": "count",
      "field": "c.id",
      "alias": "camera_count"
    }
  ],
  "group_by": [
    "c.created_at"
  ],
  "sort": [
    {
      "field": "c.created_at",
      "order": "asc"
    }
  ],
  "limit": 1000
}