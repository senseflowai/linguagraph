{
  "action": "find",
  "start": {
    "label": "Camera",
    "alias": "c"
  },
  "traversals": [],
  "filters": [
    {
      "field": "c.name",
      "op": "eq",
      "value": "TargetAI - Openspace"
    }
  ],
  "return": [
    {
      "field": "c.id",
      "alias": "id"
    },
    {
      "field": "c.name",
      "alias": "name"
    },
    {
      "field": "c.state",
      "alias": "state"
    },
    {
      "field": "c.snapshot_url",
      "alias": "snapshot_url"
    }
  ],
  "limit": 25
}